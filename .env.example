NEXT_PUBLIC_SUPABASE_URL=https://rqzwdzhphxuayqwptqia.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
ADMIN_EMAILS=admin@example.com,second-admin@example.com

# Public origin of the deployed web app (used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_INDIVIDUAL_PRICE_ID=
# EUR 399/month recurring base price; quantity is always 1 and includes 3 seats.
STRIPE_TEAM_PRICE_ID=
# EUR 99/month recurring price; quantity is only seats above the 3 included seats.
STRIPE_TEAM_EXTRA_SEAT_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=
STRIPE_CUSTOMER_PORTAL_CONFIGURATION_ID=
STRIPE_TAX_ENABLED=false

# Pipeline healthchecks (Healthchecks.io or compatible URLs)
DISCOVERY_HEALTHCHECK_URL=
CLASSIFIER_HEALTHCHECK_URL=
FULL_TEXT_HEALTHCHECK_URL=

# Paper classifier — pick one LLM provider
# Local development only (free, M2 Mac recommended); never use ollama in production:
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
# Cloud options:
# LLM_PROVIDER=groq
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.4-nano
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5

# Optional aggregate system reasoner. These are intentionally separate from extraction.
# No model call occurs unless `paper-classifier reason-system ... --execute` is used.
REASONING_LLM_PROVIDER=
REASONING_LLM_MODEL=
REASONING_LLM_API_KEY=

# Paper discovery
DISCOVERY_CONTACT_EMAIL=
# Free key from https://openalex.org/settings/api; required for production-scale runs.
OPENALEX_API_KEY=
