   "version": 1,
   "versionNonce": 1049272771,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "1 schema gate: invalid claim/relationship\n   types \u2192 dropped\n2 span gate: evidence_text must appear\n   VERBATIM in title/abstract (case-insens.);\n   stored span = source's own slice +\n   char offsets; no match \u2192 dropped\n3 inference gate: inferred claims without\n   a written rationale \u2192 dropped\n4 relationship gate: direction matrix enforced\n   (e.g. failure_mode\u2192caused_by\u2192cause)\n   \u26a0 relationship quotes NOT verified (gap)",
   "fontSize": 10.5,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "1 schema gate: invalid claim/relationship\n   types \u2192 dropped\n2 span gate: evidence_text must appear\n   VERBATIM in title/abstract (case-insens.);\n   stored span = source's own slice +\n   char offsets; no match \u2192 dropped\n3 inference gate: inferred claims without\n   a written rationale \u2192 dropped\n4 relationship gate: direction matrix enforced\n   (e.g. failure_mode\u2192caused_by\u2192cause)\n   \u26a0 relationship quotes NOT verified (gap)",
   "lineHeight": 1.25,
   "baseline": 10.5
  },
