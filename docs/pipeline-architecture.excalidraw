   "versionNonce": 849613033,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "one API call per (journal \u00d7 keyword) pair:\n17 journals \u00d7 28 queries = 476 calls\nper weekly run; each call returns up to\n25 papers for that journal matching\nthat keyword (cursor-paginated).\noptimization option: OR all 17 ISSNs\nin one filter \u2192 28 calls",
   "fontSize": 10.5,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "one API call per (journal \u00d7 keyword) pair:\n17 journals \u00d7 28 queries = 476 calls\nper weekly run; each call returns up to\n25 papers for that journal matching\nthat keyword (cursor-paginated).\noptimization option: OR all 17 ISSNs\nin one filter \u2192 28 calls",
   "lineHeight": 1.25,
   "baseline": 10.5
  },
