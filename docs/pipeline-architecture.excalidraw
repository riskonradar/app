   "boundElements": null,
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "Crack/fracture \u00b7 Fatigue \u00b7 Wear/rubbing\nCorrosion/pitting \u00b7 FOD \u00b7 Creep \u00b7 Erosion\nBearing fault \u00b7 Overheating \u00b7 \u2026\nflat list, lives in Python, applied in the\nwrite path; unknown mechanisms pass\nthrough as free text; no hierarchy \u2014\nLCF/HCF/fretting all collapse to 'Fatigue'",
   "fontSize": 10.5,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "Crack/fracture \u00b7 Fatigue \u00b7 Wear/rubbing\nCorrosion/pitting \u00b7 FOD \u00b7 Creep \u00b7 Erosion\nBearing fault \u00b7 Overheating \u00b7 \u2026\nflat list, lives in Python, applied in the\nwrite path; unknown mechanisms pass\nthrough as free text; no hierarchy \u2014\nLCF/HCF/fretting all collapse to 'Fatigue'",
   "lineHeight": 1.25,
   "baseline": 10.5
  },
