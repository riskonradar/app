   "isDeleted": false,
   "boundElements": null,
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "3 match keys, tried in order:\n1 canonical DOI = normalized DOI\n   (strip 'https://doi.org/' & 'doi:',\n   lowercase, trim trailing dot)\n2 title fingerprint (lowercase ASCII,\n   strip non-alphanumerics) + pub. year\n3 SHA-256 of normalized abstract",
   "fontSize": 10.5,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "3 match keys, tried in order:\n1 canonical DOI = normalized DOI\n   (strip 'https://doi.org/' & 'doi:',\n   lowercase, trim trailing dot)\n2 title fingerprint (lowercase ASCII,\n   strip non-alphanumerics) + pub. year\n3 SHA-256 of normalized abstract",
   "lineHeight": 1.25,
   "baseline": 10.5
  },
