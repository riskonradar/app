   "boundElements": null,
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "deterministic, no LLM \u2014 re-runnable\nover all 15k claims:\n1 exact name match vs taxonomy\n2 alias match (AGB \u2192 accessory gearbox)\n3 trigram fuzzy similarity \u2265 0.45\n\u2192 writes claim_component_link\n   {node id, match score, method}\n4 no match \u2192 taxonomy inbox: human\n   adds alias / adds node / rejects",
   "fontSize": 10.5,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "deterministic, no LLM \u2014 re-runnable\nover all 15k claims:\n1 exact name match vs taxonomy\n2 alias match (AGB \u2192 accessory gearbox)\n3 trigram fuzzy similarity \u2265 0.45\n\u2192 writes claim_component_link\n   {node id, match score, method}\n4 no match \u2192 taxonomy inbox: human\n   adds alias / adds node / rejects",
   "lineHeight": 1.25,
   "baseline": 10.5
  },
