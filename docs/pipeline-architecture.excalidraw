  {
   "id": "el058",
   "type": "text",
   "x": 1272,
   "y": 682,
   "width": 377,
   "height": 196,
   "angle": 0,
   "strokeColor": "#868e96",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "strokeWidth": 1,
   "strokeStyle": "solid",
   "roughness": 1,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "roundness": null,
   "seed": 383651995,
   "version": 1,
   "versionNonce": 228515503,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "\"You extract reliability engineering evidence for an\nevidence-backed FMEA product. Return only valid JSON\u2026\"\n\u00b7 claims: 13 types (component, failure_mode, cause,\n   effect, control, corrective_action, analysis_method,\n   application, operating_context, detection_method,\n   maintenance_action, material, environment)\n\u00b7 relationships: 8 types (has_failure_mode, caused_by,\n   has_effect, mitigated_by, detected_by, corrected_by,\n   analysed_by, has_context)\n\u00b7 \"Direct claims must use evidence_text copied exactly\n   from the title or abstract.\"\n\u00b7 \"Prefer atomic claims: one fact per claim row.\"\n\u00b7 embeds 26 canonical failure-mode labels (Crack/fracture,\n   Fatigue, FOD, Wear/rubbing, Corrosion/pitting, Creep\u2026)\n\u00b7 direction rules, e.g. failure_mode -> caused_by -> cause",
   "fontSize": 10.5,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "\"You extract reliability engineering evidence for an\nevidence-backed FMEA product. Return only valid JSON\u2026\"\n\u00b7 claims: 13 types (component, failure_mode, cause,\n   effect, control, corrective_action, analysis_method,\n   application, operating_context, detection_method,\n   maintenance_action, material, environment)\n\u00b7 relationships: 8 types (has_failure_mode, caused_by,\n   has_effect, mitigated_by, detected_by, corrected_by,\n   analysed_by, has_context)\n\u00b7 \"Direct claims must use evidence_text copied exactly\n   from the title or abstract.\"\n\u00b7 \"Prefer atomic claims: one fact per claim row.\"\n\u00b7 embeds 26 canonical failure-mode labels (Crack/fracture,\n   Fatigue, FOD, Wear/rubbing, Corrosion/pitting, Creep\u2026)\n\u00b7 direction rules, e.g. failure_mode -> caused_by -> cause",
   "lineHeight": 1.25,
   "baseline": 10.5
  },
  {
   "id": "el059",
   "type": "text",
