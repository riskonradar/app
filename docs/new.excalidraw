      "boundElements": [],
      "updated": 1783720100215,
      "link": null,
      "locked": false,
      "text": "deterministic, no LLM — re-runnable\nover all 15k claims:\n1 exact name match vs taxonomy\n2 alias match (AGB → accessory gearbox)\n3 trigram fuzzy similarity ≥ 0.45\n→ writes claim_component_link\n   {node id, match score, method}\n4 no match → taxonomy inbox: human\n   adds alias / adds node / rejects",
      "fontSize": 10.5,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "deterministic, no LLM — re-runnable\nover all 15k claims:\n1 exact name match vs taxonomy\n2 alias match (AGB → accessory gearbox)\n3 trigram fuzzy similarity ≥ 0.45\n→ writes claim_component_link\n   {node id, match score, method}\n4 no match → taxonomy inbox: human\n   adds alias / adds node / rejects",
      "lineHeight": 1.25,
      "baseline": 10.5,
      "index": "b05",
      "autoResize": true
    },
