    {
      "id": "el062",
      "type": "text",
      "x": 1272,
      "y": 1042,
      "width": 299,
      "height": 144,
      "angle": 0,
      "strokeColor": "#868e96",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 696119838,
      "version": 2,
      "versionNonce": 1128887041,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783717951788,
      "link": null,
      "locked": false,
      "text": "1 schema gate: invalid claim/relationship\n   types → dropped\n2 span gate: evidence_text must appear\n   VERBATIM in title/abstract (case-insens.);\n   stored span = source's own slice +\n   char offsets; no match → dropped\n3 inference gate: inferred claims without\n   a written rationale → dropped\n4 relationship gate: direction matrix enforced\n   (e.g. failure_mode→caused_by→cause)\n   ⚠ relationship quotes NOT verified (gap)",
      "fontSize": 10.5,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1 schema gate: invalid claim/relationship\n   types → dropped\n2 span gate: evidence_text must appear\n   VERBATIM in title/abstract (case-insens.);\n   stored span = source's own slice +\n   char offsets; no match → dropped\n3 inference gate: inferred claims without\n   a written rationale → dropped\n4 relationship gate: direction matrix enforced\n   (e.g. failure_mode→caused_by→cause)\n   ⚠ relationship quotes NOT verified (gap)",
      "lineHeight": 1.25,
      "baseline": 10.5,
      "index": "az",
      "autoResize": true
    },
