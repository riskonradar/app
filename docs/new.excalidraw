      "seed": 383651995,
      "version": 4,
      "versionNonce": 1876008676,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783719086356,
      "link": null,
      "locked": false,
      "text": "\"You extract reliability engineering evidence for an\nevidence-backed FMEA product. Return only valid JSON…\"\n· claims: 13 types (component, failure_mode, cause,\n   effect, control, corrective_action, analysis_method,\n   application, operating_context, detection_method,\n   maintenance_action, material, environment)\n· relationships: 8 types (has_failure_mode, caused_by,\n   has_effect, mitigated_by, detected_by, corrected_by,\n   analysed_by, has_context)\n· \"Direct claims must use evidence_text copied exactly\n   from the title or abstract.\"\n· \"Prefer atomic claims: one fact per claim row.\"\n· embeds 26 canonical failure-mode labels (Crack/fracture,\n   Fatigue, FOD, Wear/rubbing, Corrosion/pitting, Creep…)\n· direction rules, e.g. failure_mode -> caused_by -> cause",
      "fontSize": 10.5,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\"You extract reliability engineering evidence for an\nevidence-backed FMEA product. Return only valid JSON…\"\n· claims: 13 types (component, failure_mode, cause,\n   effect, control, corrective_action, analysis_method,\n   application, operating_context, detection_method,\n   maintenance_action, material, environment)\n· relationships: 8 types (has_failure_mode, caused_by,\n   has_effect, mitigated_by, detected_by, corrected_by,\n   analysed_by, has_context)\n· \"Direct claims must use evidence_text copied exactly\n   from the title or abstract.\"\n· \"Prefer atomic claims: one fact per claim row.\"\n· embeds 26 canonical failure-mode labels (Crack/fracture,\n   Fatigue, FOD, Wear/rubbing, Corrosion/pitting, Creep…)\n· direction rules, e.g. failure_mode -> caused_by -> cause",
      "lineHeight": 1.25,
      "baseline": 10.5,
      "index": "av",
      "autoResize": true
    },
