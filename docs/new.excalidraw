    {
      "id": "el058",
      "type": "text",
      "x": 1272,
      "y": 681.7587316176471,
      "width": 305.5602111816406,
      "height": 196.875,
      "angle": 0,
      "strokeColor": "#868e96",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
