#!/usr/bin/env bash

set -u

variable_name="${1:-}"
event="${2:-success}"

if [[ -z "$variable_name" ]]; then
  exit 0
fi

url="${!variable_name:-}"
if [[ -z "$url" ]]; then
  exit 0
fi

case "$event" in
  start)
    target="${url%/}/start"
    ;;
  fail)
    target="${url%/}/fail"
    ;;
  result)
    if [[ "${SERVICE_RESULT:-success}" == "success" ]]; then
      exit 0
    fi
    target="${url%/}/fail"
    ;;
  success)
    target="${url%/}"
    ;;
  *)
    echo "Unknown healthcheck event: $event" >&2
    exit 2
    ;;
esac

if ! curl --fail --silent --show-error \
  --max-time 10 \
  --retry 2 \
  --output /dev/null \
  "$target"; then
  echo "Healthcheck ping failed for ${variable_name} (${event}); continuing." >&2
fi

# Monitoring must never become a runtime dependency of the pipeline.
exit 0
